{
  "name": "nutrino",
  "version": "1.0.0",
  "description": "Telegram bot for AI calorie tracking with Telegram Stars subscription",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute nutrino-db-bot --file=./migrations/0001_init.sql",
    "db:create": "wrangler d1 create nutrino-db-bot",
    "set-webhook": "curl -X POST \"https://api.telegram.org/bot${BOT_TOKEN}/setWebhook?url=https://nutrino-bot.${CLOUDFLARE_SUBDOMAIN}.workers.dev/webhook\""
  },
  "keywords": ["telegram", "bot", "calorie", "tracking", "cloudflare"],
  "license": "ISC",
  "dependencies": {
    "grammy": "^1.43.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.1",
    "typescript": "^5.8.3"
  }
}
